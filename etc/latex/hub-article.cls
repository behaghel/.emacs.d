\newcommand{\HubArticleDropCap}[2]{%
  \lettrine[lines=2,findent=0em,nindent=0em,slope=0pt,loversize=0,lhang=0.3]%
    {\HubArticleSerif\bfseries\color{HubArticleInk}#1}{\textsc{#2}}%
