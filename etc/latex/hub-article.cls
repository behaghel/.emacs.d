\AtBeginDocument{\arrayrulecolor{HubArticleTableRule}}
\DeclareCaptionFont{hubarticletablecaption}{\HubArticleSans\footnotesize}
\captionsetup[table]{font=hubarticletablecaption,labelfont={bf,color=HubArticleAccentMuted},textfont={color=HubArticleTableCaptionText},labelsep=period,justification=centering,singlelinecheck=false,skip=0.55em}
\captionsetup[figure]{font=hubarticletablecaption,labelfont={bf,color=HubArticleAccentMuted},textfont={color=HubArticleTableCaptionText},labelsep=period,justification=centering,singlelinecheck=false,skip=0.55em}
\makeatletter
\def\ps@plain{%
  \let\@mkboth\@gobbletwo
  \let\@oddhead\@empty
  \let\@evenhead\@empty
  \def\@oddfoot{%
    \hb@xt@\textwidth{%
      \hfill
      \makebox[0pt][l]{%
        \hspace{27mm}%
        \large\textcolor{HubArticleRule}{\thepage}%
      }%
    }%
  }%
  \let\@evenfoot\@oddfoot}
\makeatother
\pagestyle{plain}
\let\HubArticleOriginalTable\table
\let\HubArticleOriginalEndTable\endtable
\renewenvironment{table}[1][]{%
  \HubArticleOriginalTable[#1]%
  \color{HubArticleInk}%
}{%
  \HubArticleOriginalEndTable
}

\newcommand{\HubArticleDocumentTitle}{}
\newcommand{\HubArticleEyebrowBlock}{}
\newcommand{\HubArticleMetaSeparator}{\hspace{0.65em}{\textcolor{HubArticleAccentMuted}{\textbullet}}\hspace{0.65em}}
\newcommand{\HubArticleAccentMarker}{\textcolor{HubArticleAccentMuted}{\rule{26mm}{0.7pt}}}
\newcommand{\HubArticleEyebrow}[1]{%
  {\HubArticleSans\small\addfontfeature{LetterSpace=10.0}\textcolor{HubArticleAccentMuted}{\MakeUppercase{#1}}\par}%
  \vspace{1.15em}%
}
\newcommand{\HubArticleTitle}[1]{%
  \gdef\HubArticleDocumentTitle{#1}%
  {\HubArticleSerif\fontsize{28}{32}\selectfont\textcolor{HubArticleInk}{#1}\par}%
  \vspace{0.8em}%
}
\newcommand{\HubArticleDek}[1]{%
  \def\HubArticleTemp{#1}%
  \ifx\HubArticleTemp\empty\else
    {\HubArticleSerif\large\itshape\textcolor{HubArticleStandfirst}{#1}\par}%
    \vspace{1.2em}%
  \fi
}
\newcommand{\HubArticleMeta}[2]{%
  {\HubArticleSans\footnotesize\raggedleft\textcolor{HubArticleMuted}{#1\HubArticleMetaSeparator #2}\par}%
}
\newcommand{\HubArticleMarginMarker}[1]{%
  \marginpar{%
    \raggedright
    \HubArticleSans\scriptsize\textcolor{HubArticleAccentMuted}{#1}}%
}
\newcommand{\HubArticleMarginZone}[1]{%
  \HubArticleMarginMarker{#1}%
}
\newcommand{\HubArticleSidenoteMark}[1]{%
  \raisebox{0.55ex}{\HubArticleSans\fontsize{6.5}{7}\selectfont\textcolor{HubArticleMarginaliaMarker}{#1}}%
}
\newcommand{\HubArticleSidenoteMargin}[2]{%
  \marginpar{%
    \raggedright
    \HubArticleSans\scriptsize\color{HubArticleMarginaliaText}%
    \HubArticleSidenoteMark{#1}\hspace{0.35em}%
    #2\par}%
}
\newcommand{\HubArticleSidenote}[1]{%
  \refstepcounter{footnote}%
  \edef\HubArticleSidenoteNumber{\number\value{footnote}}%
  \textsuperscript{\textcolor{HubArticleMarginaliaMarker}{\HubArticleSidenoteNumber}}%
  \expandafter\HubArticleSidenoteMargin\expandafter{\HubArticleSidenoteNumber}{#1}%
}
\newcommand{\HubArticleBold}[1]{{\color{HubArticleBoldColor}\textbf{#1}}}
\newcommand{\HubArticleInlineCode}[1]{%
  \begingroup
  \HubArticleMono\footnotesize\textcolor{HubArticleCodeInk}{#1}%
  \endgroup
}
\let\HubArticleOriginalTexttt\texttt
\renewcommand{\texttt}[1]{\HubArticleInlineCode{#1}}
\newcolumntype{H}{>{\raggedright\arraybackslash\hspace{0pt}}X}
\newcommand{\HubArticleTableHeaderCell}[1]{{\HubArticleSans\footnotesize\addfontfeature{LetterSpace=4.0}\textcolor{HubArticleTableHeaderColor}{\MakeUppercase{#1}}\strut}}
\newcommand{\HubArticleTableBodyCell}[1]{{\textcolor{HubArticleInk}{#1}\strut}}
\newcommand{\HubArticleTableHeadRule}{\noalign{\vskip 0.35em\color{HubArticleTableRule}\hrule height 0.35pt\vskip 0.35em}}
\newcommand{\HubArticleCenteredBlock}[1]{\makebox[\linewidth][c]{\makebox[\HubArticleTableWidth][c]{#1}}}
\newcommand{\HubArticleFigureImage}[1]{\makebox[\linewidth][c]{\hspace*{\HubArticleFigureAlignCorrection}\makebox[\HubArticleTableWidth][c]{#1}}}
\newenvironment{HubArticleTable}{%
  \par\medskip\noindent\begin{center}\begin{minipage}{\HubArticleTableWidth}\centering
  \begingroup
  \setlength{\tabcolsep}{4.5pt}%
  \renewcommand{\arraystretch}{1.16}%
  \color{HubArticleInk}%
}{%
  \endgroup
  \end{minipage}\end{center}%
  \par\medskip
}
\newcommand{\HubArticleDefinitionTerm}[1]{{\HubArticleSans\normalsize\textcolor{HubArticleAccentMuted}{\textbf{#1:}}}}
\AtBeginEnvironment{description}{\setlength{\itemsep}{0.22em}\setlength{\topsep}{0.45em}\setlength{\parsep}{0pt}\setlength{\labelsep}{0.45em}}

\newenvironment{hubarticleopener}{%
  \par\vspace*{1.1em}\noindent
  \begingroup
  \thispagestyle{empty}%
  \HubArticleAccentMarker\par
  \vspace{1.35em}%
}{%
  \par\vspace{1.8em}%
  \endgroup
}

\newenvironment{standfirst}{%
  \par\medskip\noindent
  \begingroup
  \HubArticleSerif\large\color{HubArticleStandfirst}\ignorespaces
}{%
  \par
  \endgroup
  \medskip
}

\newcommand{\HubArticleCalloutRuleColor}{HubArticleCalloutRule}
\newcommand{\HubArticleCalloutTitle}[1]{%
  \vspace{0.2em}{\HubArticleSans\footnotesize\bfseries\textcolor{HubArticleAccentMuted}{#1}}\par\vspace{0.1em}%
}

\newenvironment{HubArticleCallout}{}{}
\renewenvironment{HubArticleCallout}{%
  \par\addvspace{0.95em}\noindent
  \begingroup
  \HubArticleSans\small\color{HubArticleInk}%
  \setlength{\leftskip}{1.2em}%
  \setlength{\rightskip}{1em}%
  \noindent\textcolor{\HubArticleCalloutRuleColor}{\rule{24mm}{0.4pt}}\par\nobreak
  \vspace{0.2em}%
  \ignorespaces
}{%
  \par
  \endgroup
  \addvspace{0.95em}%
}
\newenvironment{callout}{%
  \begin{HubArticleCallout}%
}{%
  \end{HubArticleCallout}%
}

\colorlet{HubArticleCalloutInfoRule}{HubArticleLightAccentMuted}
\newenvironment{info}{%
  \renewcommand{\HubArticleCalloutRuleColor}{HubArticleCalloutInfoRule}%
  \begin{HubArticleCallout}%
}{%
  \end{HubArticleCallout}%
}

\colorlet{HubArticleCalloutWarningRule}{HubArticleCodeConstantInk}
\newenvironment{warning}{%
  \renewcommand{\HubArticleCalloutRuleColor}{HubArticleCalloutWarningRule}%
  \begin{HubArticleCallout}%
}{%
  \end{HubArticleCallout}%
}

\newenvironment{authorsnote}{%
  \begin{HubArticleCallout}%
}{%
  \end{HubArticleCallout}%
}

\newenvironment{HubArticleQuote}{%
  \par\medskip\noindent
  \begingroup
  \HubArticleSerif\itshape\color{HubArticleStandfirst}%
  \setlength{\rightskip}{1.1em}%
  \setlength{\tabcolsep}{0pt}%
  \begin{tabular}{@{}!{\textcolor{HubArticleQuoteRule}{\vrule width 0.55pt}\hspace{0.85em}}p{\dimexpr\linewidth-0.85em-0.55pt\relax}@{}}%
  \ignorespaces
}{%
  \unskip
  \end{tabular}%
  \par
  \endgroup
  \medskip
}
\renewenvironment{quote}{%
  \begin{HubArticleQuote}%
}{%
  \end{HubArticleQuote}%
}

\newenvironment{HubArticleEpigraph}{%
  \par\addvspace{1.0em}\noindent
  \begin{flushright}%
  \begin{minipage}{0.68\linewidth}%
  \begingroup
  \HubArticleSerif\small\itshape\color{HubArticleStandfirst}%
  \setlength{\parindent}{0pt}%
  \setlength{\parskip}{0.35em}%
  \raggedleft
  \obeylines
  \ignorespaces
}{%
  \par
  \endgroup
  \end{minipage}%
  \end{flushright}%
  \par\addvspace{2.1em}%
}
\newenvironment{epigraph}{%
  \begin{HubArticleEpigraph}%
}{%
  \end{HubArticleEpigraph}%
}
